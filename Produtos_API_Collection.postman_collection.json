{
  "info": {
    "_postman_id": "produtos-api-collection",
    "name": "Produtos API - Spring Boot",
    "description": "Coleção completa para testar a API REST de Produtos com autenticação JWT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "123456"
