          "name": "Deletar Produto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verifica se a resposta tem status 204 (No Content)",
                  "pm.test('Status code é 204 (No Content)', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/produtos/{{produto_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "produtos",
                "{{produto_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Buscar Produto Inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verifica se a resposta tem status 404",
                  "pm.test('Status code é 404 (Not Found)', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "// Verifica se a resposta tem a estrutura de erro",
                  "var jsonResponse = pm.response.json();",
                  "pm.test('Resposta de erro tem campos esperados', function () {",
                  "    pm.expect(jsonResponse).to.have.property('status');",
                  "    pm.expect(jsonResponse).to.have.property('erro');",
                  "    pm.expect(jsonResponse).to.have.property('mensagem');",
                  "    pm.expect(jsonResponse.status).to.equal(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
