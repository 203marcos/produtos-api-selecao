            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Notebook Dell - Atualizado\",\n  \"preco\": 4500.00,\n  \"descricao\": \"Notebook atualizado com processador i9 e 32GB de RAM\",\n  \"categoria\": \"Eletrônicos Premium\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/produtos/{{produto_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
