  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login - Gerar Token JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verifica se a resposta tem status 200",
                  "pm.test('Status code é 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Extrai o token da resposta",
                  "var jsonResponse = pm.response.json();",
                  "pm.test('Token JWT foi retornado', function () {",
                  "    pm.expect(jsonResponse).to.have.property('token');",
                  "});",
                  "",
                  "// Armazena o token na variável de coleção para usar em outras requisições",
                  "if (jsonResponse.token) {",
                  "    pm.collectionVariables.set('jwt_token', jsonResponse.token);",
                  "    console.log('Token armazenado: ' + jsonResponse.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@exemplo.com\",\n  \"senha\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login - Credenciais Inválidas (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verifica se a resposta tem status 401",
                  "pm.test('Status code é 401 (Unauthorized)', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "// Verifica se a resposta tem a estrutura de erro",
                  "var jsonResponse = pm.response.json();",
                  "pm.test('Resposta de erro tem campo mensagem', function () {",
                  "    pm.expect(jsonResponse).to.have.property('mensagem');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@exemplo.com\",\n  \"senha\": \"senhaErrada\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
