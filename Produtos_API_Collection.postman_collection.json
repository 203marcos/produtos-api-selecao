    {
      "name": "Produtos - CRUD",
      "item": [
        {
          "name": "Criar Produto",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Gera um timestamp para usar no nome do produto",
                  "var timestamp = new Date().getTime();",
                  "pm.environment.set('produto_timestamp', timestamp);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verifica se a resposta tem status 201 (Created)",
                  "pm.test('Status code é 201 (Created)', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "// Extrai o ID do produto criado",
                  "var jsonResponse = pm.response.json();",
                  "pm.test('Produto criado tem ID', function () {",
                  "    pm.expect(jsonResponse).to.have.property('id');",
                  "});",
                  "",
                  "// Armazena o ID para usar em requisições subsequentes",
                  "if (jsonResponse.id) {",
                  "    pm.collectionVariables.set('produto_id', jsonResponse.id);",
                  "    console.log('Produto ID armazenado: ' + jsonResponse.id);",
                  "}",
                  "",
                  "// Verifica os campos da resposta",
                  "pm.test('Produto tem nome, preço, descrição e categoria', function () {",
                  "    pm.expect(jsonResponse).to.have.property('nome');",
                  "    pm.expect(jsonResponse).to.have.property('preco');",
                  "    pm.expect(jsonResponse).to.have.property('descricao');",
                  "    pm.expect(jsonResponse).to.have.property('categoria');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Notebook Dell {{produto_timestamp}}\",\n  \"preco\": 3500.00,\n  \"descricao\": \"Notebook com processador i7 e 16GB de RAM\",\n  \"categoria\": \"Eletrônicos\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/produtos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "produtos"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Listar Todos os Produtos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verifica se a resposta tem status 200",
                  "pm.test('Status code é 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Verifica se a resposta é um array",
                  "var jsonResponse = pm.response.json();",
                  "pm.test('Resposta é uma lista', function () {",
                  "    pm.expect(jsonResponse).to.be.an('array');",
                  "});",
                  "",
                  "// Verifica se pelo menos um produto foi retornado",
                  "pm.test('Lista contém pelo menos um produto', function () {",
                  "    pm.expect(jsonResponse.length).to.be.greaterThan(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/produtos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "produtos"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Buscar Produto por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verifica se a resposta tem status 200",
                  "pm.test('Status code é 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Extrai e verifica os dados do produto",
                  "var jsonResponse = pm.response.json();",
                  "pm.test('Produto tem os campos esperados', function () {",
                  "    pm.expect(jsonResponse).to.have.property('id');",
                  "    pm.expect(jsonResponse).to.have.property('nome');",
                  "    pm.expect(jsonResponse).to.have.property('preco');",
                  "    pm.expect(jsonResponse).to.have.property('descricao');",
                  "    pm.expect(jsonResponse).to.have.property('categoria');",
                  "});",
                  "",
                  "// Verifica se o ID retornado corresponde ao ID requisitado",
                  "pm.test('ID do produto corresponde à requisição', function () {",
                  "    pm.expect(jsonResponse.id).to.equal(parseInt(pm.collectionVariables.get('produto_id')));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/produtos/{{produto_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "produtos",
                "{{produto_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Atualizar Produto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verifica se a resposta tem status 200",
                  "pm.test('Status code é 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Verifica se os dados foram atualizados",
                  "var jsonResponse = pm.response.json();",
                  "pm.test('Produto foi atualizado corretamente', function () {",
                  "    pm.expect(jsonResponse.nome).to.include('Atualizado');",
                  "    pm.expect(jsonResponse.preco).to.equal(4500.00);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
